generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  password     String
  role         Role          @default(ADMIN)
  purchases    Purchase[]    @relation("UserPurchases")
  sales        Sale[]        @relation("UserSales")
  expenses     Expense[]     @relation("UserExpenses")
  salePayments SalePayment[] @relation("UserSalePayments")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum Role {
  ADMIN
  USER
}

model Product {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String              @unique
  currentStockKg    Decimal             @default(0) @db.Decimal(12, 2)
  averageCostPerKg  Decimal             @default(0) @db.Decimal(14, 2)
  isActive          Boolean             @default(true)
  purchases         Purchase[]
  sales             Sale[]
  inventoryMovements InventoryMovement[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

enum BaleClothType {
  PUTIH
  WARNA
}

enum BaleGrade {
  A1
  B2
  C3
}

model BalePrice {
  id          String        @id @default(cuid())
  clothType   BaleClothType
  grade       BaleGrade
  pricePerBal Decimal       @db.Decimal(14, 2)
  notes       String?
  customers   Customer[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([clothType, grade])
  @@index([clothType])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String     @unique
  phone     String?
  address   String?
  notes     String?
  purchases Purchase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  storeName String   @unique
  ownerName String?
  phone     String?
  address   String?
  notes     String?
  preferredBalePriceId String?
  preferredBalePrice   BalePrice? @relation(fields: [preferredBalePriceId], references: [id], onDelete: SetNull)
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([preferredBalePriceId])
}

model Purchase {
  id               String            @id @default(cuid())
  supplierId       String
  productId        String
  purchaseDate     DateTime
  quantityKg       Decimal           @db.Decimal(12, 2)
  pricePerKg       Decimal           @db.Decimal(14, 2)
  subtotal         Decimal           @db.Decimal(14, 2)
  transportExpense Decimal           @default(0) @db.Decimal(14, 2)
  totalExpense     Decimal           @db.Decimal(14, 2)
  notes            String?
  createdById      String
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy        User              @relation("UserPurchases", fields: [createdById], references: [id], onDelete: Restrict)
  inventoryMovement InventoryMovement?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([supplierId])
  @@index([productId])
  @@index([purchaseDate])
}

model Sale {
  id                     String            @id @default(cuid())
  customerId             String
  productId              String
  saleDate               DateTime
  quantityKg             Decimal           @db.Decimal(12, 2)
  sellingPricePerKg      Decimal           @db.Decimal(14, 2)
  subtotal               Decimal           @db.Decimal(14, 2)
  deliveryExpense        Decimal           @default(0) @db.Decimal(14, 2)
  additionalExpense      Decimal           @default(0) @db.Decimal(14, 2)
  totalTransactionValue  Decimal           @db.Decimal(14, 2)
  paymentStatus          PaymentStatus     @default(UNPAID)
  amountPaid             Decimal           @default(0) @db.Decimal(14, 2)
  outstandingAmount      Decimal           @db.Decimal(14, 2)
  costBasisPerKgSnapshot Decimal           @default(0) @db.Decimal(14, 2)
  estimatedCogs          Decimal           @default(0) @db.Decimal(14, 2)
  estimatedProfit        Decimal           @default(0) @db.Decimal(14, 2)
  notes                  String?
  createdById            String
  customer               Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product                Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy              User              @relation("UserSales", fields: [createdById], references: [id], onDelete: Restrict)
  salePayments           SalePayment[]
  inventoryMovement      InventoryMovement?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([customerId])
  @@index([productId])
  @@index([saleDate])
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model SalePayment {
  id          String   @id @default(cuid())
  saleId      String
  paymentDate DateTime
  amount      Decimal  @db.Decimal(14, 2)
  notes       String?
  createdById String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("UserSalePayments", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([saleId])
  @@index([paymentDate])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  categoryId  String
  expenseDate DateTime
  amount      Decimal         @db.Decimal(14, 2)
  description String
  createdById String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy   User            @relation("UserExpenses", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId])
  @@index([expenseDate])
}

model InventoryMovement {
  id               String                @id @default(cuid())
  productId        String
  occurredAt       DateTime
  movementType     InventoryMovementType
  quantityKg       Decimal               @db.Decimal(12, 2)
  inboundTotalCost Decimal?              @db.Decimal(14, 2)
  notes            String?
  purchaseId       String?               @unique
  saleId           String?               @unique
  product          Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchase         Purchase?             @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  sale             Sale?                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([productId, occurredAt])
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
}

model LandingSetting {
  id        String   @id @default(cuid())
  section   String   // hero, stats, products, about, order, cta, footer
  key       String   // title, subtitle, description, dll
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, key])
  @@index([section])
}
