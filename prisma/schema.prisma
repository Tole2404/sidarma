generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  password     String
  role         Role          @default(ADMIN)
  purchases    Purchase[]    @relation("UserPurchases")
  sales        Sale[]        @relation("UserSales")
  expenses     Expense[]     @relation("UserExpenses")
  salePayments SalePayment[] @relation("UserSalePayments")
  bongkarans   Bongkaran[]   @relation("UserBongkarans")
  bongkaranSorts BongkaranSort[] @relation("UserBongkaranSorts")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum Role {
  ADMIN
  USER
}

model Product {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String              @unique
  currentStockKg    Decimal             @default(0) @db.Decimal(12, 2)
  averageCostPerKg  Decimal             @default(0) @db.Decimal(14, 2)
  isActive          Boolean             @default(true)
  purchases         Purchase[]
  sales             Sale[]
  inventoryMovements InventoryMovement[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

enum BaleClothType {
  PUTIH
  WARNA
}

enum BaleGrade {
  A1
  B2
  C3
}

model BalePrice {
  id          String        @id @default(cuid())
  clothType   BaleClothType
  grade       BaleGrade
  pricePerBal Decimal       @db.Decimal(14, 2)
  notes       String?
  customers   Customer[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([clothType, grade])
  @@index([clothType])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String     @unique
  phone     String?
  address   String?
  notes     String?
  purchases Purchase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  storeName String   @unique
  ownerName String?
  phone     String?
  address   String?
  notes     String?
  preferredBalePriceId String?
  preferredBalePrice   BalePrice? @relation(fields: [preferredBalePriceId], references: [id], onDelete: SetNull)
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([preferredBalePriceId])
}

model Purchase {
  id               String            @id @default(cuid())
  supplierId       String
  productId        String
  purchaseDate     DateTime
  quantityKg       Decimal           @db.Decimal(12, 2)
  pricePerKg       Decimal           @db.Decimal(14, 2)
  subtotal         Decimal           @db.Decimal(14, 2)
  transportExpense Decimal           @default(0) @db.Decimal(14, 2)
  totalExpense     Decimal           @db.Decimal(14, 2)
  notes            String?
  createdById      String
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy        User              @relation("UserPurchases", fields: [createdById], references: [id], onDelete: Restrict)
  inventoryMovement InventoryMovement?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([supplierId])
  @@index([productId])
  @@index([purchaseDate])
}

model Sale {
  id                     String            @id @default(cuid())
  customerId             String
  productId              String
  saleDate               DateTime
  quantityKg             Decimal           @db.Decimal(12, 2)
  sellingPricePerKg      Decimal           @db.Decimal(14, 2)
  subtotal               Decimal           @db.Decimal(14, 2)
  deliveryExpense        Decimal           @default(0) @db.Decimal(14, 2)
  additionalExpense      Decimal           @default(0) @db.Decimal(14, 2)
  totalTransactionValue  Decimal           @db.Decimal(14, 2)
  paymentStatus          PaymentStatus     @default(UNPAID)
  amountPaid             Decimal           @default(0) @db.Decimal(14, 2)
  outstandingAmount      Decimal           @db.Decimal(14, 2)
  costBasisPerKgSnapshot Decimal           @default(0) @db.Decimal(14, 2)
  estimatedCogs          Decimal           @default(0) @db.Decimal(14, 2)
  estimatedProfit        Decimal           @default(0) @db.Decimal(14, 2)
  notes                  String?
  createdById            String
  customer               Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product                Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy              User              @relation("UserSales", fields: [createdById], references: [id], onDelete: Restrict)
  salePayments           SalePayment[]
  inventoryMovement      InventoryMovement?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([customerId])
  @@index([productId])
  @@index([saleDate])
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model SalePayment {
  id          String   @id @default(cuid())
  saleId      String
  paymentDate DateTime
  amount      Decimal  @db.Decimal(14, 2)
  notes       String?
  createdById String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("UserSalePayments", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([saleId])
  @@index([paymentDate])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  categoryId  String
  expenseDate DateTime
  amount      Decimal         @db.Decimal(14, 2)
  description String
  createdById String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy   User            @relation("UserExpenses", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId])
  @@index([expenseDate])
}

model InventoryMovement {
  id               String                @id @default(cuid())
  productId        String
  occurredAt       DateTime
  movementType     InventoryMovementType
  quantityKg       Decimal               @db.Decimal(12, 2)
  inboundTotalCost Decimal?              @db.Decimal(14, 2)
  notes            String?
  purchaseId       String?               @unique
  saleId           String?               @unique
  product          Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchase         Purchase?             @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  sale             Sale?                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([productId, occurredAt])
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
}

model Konveksi {
  id          String      @id @default(cuid())
  name        String      @unique
  picName     String?
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean     @default(true)
  bongkarans  Bongkaran[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum BongkaranStatus {
  PENDING_SORT
  IN_PROGRESS
  SORTED
  CANCELLED
}

model Bongkaran {
  id                  String          @id @default(cuid())
  konveksiId          String
  purchaseDate        DateTime
  quantityKg          Decimal         @db.Decimal(12, 2)
  pricePerKg          Decimal         @db.Decimal(14, 2)
  subtotal            Decimal         @db.Decimal(14, 2)
  transportExpense    Decimal         @default(0) @db.Decimal(14, 2)
  additionalExpense   Decimal         @default(0) @db.Decimal(14, 2)
  totalCost           Decimal         @db.Decimal(14, 2)
  costPerKgEffective  Decimal         @db.Decimal(14, 4)
  sortedQuantityKg    Decimal         @default(0) @db.Decimal(12, 2)
  status              BongkaranStatus @default(PENDING_SORT)
  notes               String?
  createdById         String
  konveksi            Konveksi        @relation(fields: [konveksiId], references: [id], onDelete: Restrict)
  createdBy           User            @relation("UserBongkarans", fields: [createdById], references: [id], onDelete: Restrict)
  sorts               BongkaranSort[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([konveksiId])
  @@index([purchaseDate])
  @@index([status])
}

model BongkaranSort {
  id              String    @id @default(cuid())
  bongkaranId     String
  sortDate        DateTime
  inputKg         Decimal   @db.Decimal(12, 2)
  outputPutihKg   Decimal   @db.Decimal(12, 2)
  outputWarnaKg   Decimal   @db.Decimal(12, 2)
  wasteKg         Decimal   @db.Decimal(12, 2)
  laborExpense    Decimal   @default(0) @db.Decimal(14, 2)
  totalCost       Decimal   @db.Decimal(14, 2)
  unitCostPutih   Decimal   @default(0) @db.Decimal(14, 4)
  unitCostWarna   Decimal   @default(0) @db.Decimal(14, 4)
  notes           String?
  createdById     String
  bongkaran       Bongkaran @relation(fields: [bongkaranId], references: [id], onDelete: Cascade)
  createdBy       User      @relation("UserBongkaranSorts", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([bongkaranId])
  @@index([sortDate])
}

model LandingSetting {
  id        String   @id @default(cuid())
  section   String   // hero, stats, products, about, order, cta, footer
  key       String   // title, subtitle, description, dll
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, key])
  @@index([section])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  content     String   @db.Text
  category    String   @default("Blog")
  thumbnail   String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished, publishedAt])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  company     String
  role        String?
  content     String   @db.Text
  rating      Int      @default(5)
  avatar      String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isFeatured])
}

model CareerPost {
  id           String              @id @default(cuid())
  title        String
  department   String
  location     String              @default("Bandung, Jawa Barat")
  type         String              @default("Full-time")
  description  String              @db.Text
  requirements String              @db.Text
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  applications CareerApplication[]

  @@index([isActive])
}

model CareerApplication {
  id          String     @id @default(cuid())
  postId      String
  fullName    String
  email       String
  phone       String
  coverLetter String?    @db.Text
  status      String     @default("Pending")
  post        CareerPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([postId])
}
